# Copie este arquivo para ".env" dentro da pasta api/ para rodar o backend
# sem Docker (Opção 2 do README). O ".env" já está no .gitignore e nunca
# deve ser commitado.

# Banco de Dados
DB_HOST=localhost
DB_PORT=5432
DB_NAME=biblioteca
DB_USER=postgres
DB_PASSWORD=defina_uma_senha_aqui

# JWT
# Gere um valor aleatório e longo, por exemplo com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=defina_um_segredo_aleatorio_e_longo_aqui
JWT_EXPIRES_IN=8h

# Servidor
PORT=3000
