# Variáveis usadas pelo docker-compose (docker compose up).
# Copie este arquivo para ".env" na raiz do projeto e preencha os valores reais.
# O ".env" já está no .gitignore e nunca deve ser commitado.

DB_NAME=biblioteca
DB_USER=postgres
DB_PASSWORD=defina_uma_senha_aqui
DB_PORT=5432

# Gere um valor aleatório e longo, por exemplo com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=defina_um_segredo_aleatorio_e_longo_aqui
JWT_EXPIRES_IN=8h
